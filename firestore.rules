rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Settings rules
    match /settings/store {
      allow read: if true;
      allow create, update: if isValidStoreSetting(request.resource.data);
      allow delete: if true;
    }

    // Products rules
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isValidProduct(request.resource.data) && isValidId(productId);
      allow delete: if isValidId(productId);
    }

    // Customer registrations rules
    match /customer_registrations/{userId} {
      allow read: if true;
      allow create, update: if isValidCustomerRegistration(request.resource.data) && isValidId(userId);
      allow delete: if isValidId(userId);
    }

    // Sales rules
    match /sales/{saleId} {
      allow read, list: if true;
      allow create: if isValidSale(request.resource.data) && isValidId(saleId);
      allow update, delete: if isValidId(saleId);
    }

    // Batches rules
    match /batches/{batchId} {
      allow read, list: if true;
      allow create, update: if isValidProductBatch(request.resource.data) && isValidId(batchId);
      allow delete: if isValidId(batchId);
    }
  }
}

function isValidId(id) {
  return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
}

function isValidCustomerRegistration(data) {
  return data.keys().hasAll(['uid', 'name', 'email', 'workplace', 'shiftHours', 'photoUrl', 'createdAt'])
    && data.uid is string && data.uid.size() <= 128
    && data.name is string && data.name.size() <= 200
    && data.email is string && data.email.size() <= 200
    && data.workplace is string && data.workplace.size() <= 200
    && data.shiftHours is string && data.shiftHours.size() <= 200
    && data.photoUrl is string && data.photoUrl.size() <= 1000000 // up to 1MB base64
    && data.createdAt is string && data.createdAt.size() <= 100;
}

function isValidStoreSetting(data) {
  return data.keys().hasAll(['storeName', 'pixKey', 'whatsappNumber'])
    && data.storeName is string && data.storeName.size() <= 100
    && data.pixKey is string && data.pixKey.size() <= 150
    && data.whatsappNumber is string && data.whatsappNumber.size() <= 30;
}

function isValidProduct(data) {
  return data.keys().hasAll(['id', 'name', 'price', 'available', 'category'])
    && data.id is string && data.id.size() <= 128
    && data.name is string && data.name.size() <= 100
    && (data.price is number || data.price is int) && data.price >= 0
    && data.available is bool
    && data.category is string && data.category.size() <= 50;
}

function isValidSale(data) {
  return data.keys().hasAll(['id', 'customerId', 'customerName', 'customerEmail', 'customerWorkplace', 'customerShiftHours', 'items', 'totalAmount', 'paymentMethod', 'createdAt'])
    && data.id is string && data.id.size() <= 128
    && data.customerId is string && data.customerId.size() <= 128
    && data.customerName is string && data.customerName.size() <= 200
    && data.customerEmail is string && data.customerEmail.size() <= 200
    && data.customerWorkplace is string && data.customerWorkplace.size() <= 200
    && data.customerShiftHours is string && data.customerShiftHours.size() <= 200
    && data.items is list
    && (data.totalAmount is number || data.totalAmount is int) && data.totalAmount >= 0
    && data.paymentMethod is string && (data.paymentMethod == 'later' || data.paymentMethod == 'pix')
    && data.createdAt is string && data.createdAt.size() <= 100;
}

function isValidProductBatch(data) {
  return data.keys().hasAll(['id', 'productId', 'productName', 'batchDate', 'initialQuantity', 'createdAt'])
    && data.id is string && data.id.size() <= 128
    && data.productId is string && data.productId.size() <= 128
    && data.productName is string && data.productName.size() <= 100
    && data.batchDate is string && data.batchDate.size() <= 100
    && (data.initialQuantity is number || data.initialQuantity is int) && data.initialQuantity >= 0
    && data.createdAt is string && data.createdAt.size() <= 100;
}
